FROM node:22-alpine

# Install jq for JSON handling in entrypoint
RUN apk add --no-cache jq bash

# Install Claude Code CLI globally
RUN npm install -g @anthropic-ai/claude-code

# Create workspace directory structure
RUN mkdir -p /workspace/docs /workspace/output

# Copy entrypoint
COPY infra/docker/claude-runner/entrypoint.js /opt/claude-runner/entrypoint.js

# Default workspace
WORKDIR /workspace

# Env vars expected at runtime:
#   ANTHROPIC_API_KEY  — required
#   EXECUTION_TIMEOUT  — optional override (seconds)

ENTRYPOINT ["node", "/opt/claude-runner/entrypoint.js"]
