{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "extends": "./base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strictNullChecks": true,
    "noImplicitAny": true
  }
}
