{
  "name": "@the-crew/company-design-service",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/microservices": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@the-crew/domain-core": "workspace:*",
    "@the-crew/drizzle-db": "workspace:*",
    "@the-crew/shared-types": "workspace:*",
    "drizzle-orm": "^0.39.3",
    "eventemitter2": "^6.4.9",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@the-crew/eslint-config": "workspace:*",
    "@the-crew/tsconfig": "workspace:*",
    "eslint": "^9.16.0",
    "typescript": "^5.7.3",
    "drizzle-kit": "^0.30.4",
    "vitest": "^2.1.8"
  }
}
